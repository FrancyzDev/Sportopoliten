@model IEnumerable<Sportopoliten.DAL.Entities.Product>

@{
    ViewData["Title"] = "Управление товарами";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-box me-2"></i>@ViewData["Title"]
        </h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Создать товар
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Изображение</th>
                                <th>Название</th>
                                <th>Категория</th>
                                <th>Цена</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">#@product.Id</span></td>
                                    <td>
                                        @if (product.ProductImages != null && product.ProductImages.Any())
                                        {
                                            <img src="@product.ProductImages.First().ImageUrl"
                                                 alt="@product.Title"
                                                 class="img-thumbnail"
                                                 style="width: 60px; height: 60px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-light d-flex align-items-center justify-content-center"
                                                 style="width: 60px; height: 60px; border-radius: 4px;">
                                                <i class="fas fa-image fa-2x text-muted"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <strong>@product.Title</strong>
                                        @if (!string.IsNullOrEmpty(product.Description) && product.Description.Length > 50)
                                        {
                                            <br />
                                            <small class="text-muted">@product.Description.Substring(0, 50)...</small>
                                        }
                                    </td>
                                    <td>
                                        @if (product.Category != null)
                                        {
                                            <span class="badge bg-info">@product.Category.Title</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Без категории</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="fw-bold text-primary">
                                            @product.Price.ToString() ₴
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@product.Id"
                                                   class="btn btn-sm btn-warning"
                                                   title="Редактировать">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@product.Id"
                                                   class="btn btn-sm btn-info"
                                                   title="Просмотр">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@product.Id"
                                                   class="btn btn-sm btn-danger"
                                                   title="Удалить"
                                            >
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Пагинация -->
                @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
                {
                    <nav aria-label="Пагинация" class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-box-open fa-5x text-muted"></i>
                    </div>
                    <h4 class="text-muted mb-3">Товары отсутствуют</h4>
                    <p class="text-muted mb-4">Создайте первый товар, чтобы начать продажи</p>
                    <a asp-action="Create" class="btn btn-primary btn-lg">
                        <i class="fas fa-plus me-2"></i>Создать товар
                    </a>
                </div>
            }
        </div>
    </div>
</div>