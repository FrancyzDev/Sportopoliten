@model Sportopoliten.Areas.Admin.ViewModels.Products.EditProductViewModel

@{
    ViewData["Title"] = "Редактирование товара";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="fas fa-edit me-2"></i>@ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Название товара -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Введите название товара" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <!-- Описание -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Введите описание товара"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <!-- Цена -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₴</span>
                                    <input asp-for="Price" class="form-control" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <!-- Категория -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-bold"></label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                    <option value="">-- Выберите категорию --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Существующие изображения -->
                        @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Текущие изображения</label>
                                <div class="row g-2">
                                    @for (int i = 0; i < Model.ExistingImages.Count; i++)
                                    {
                                        <div class="col-3 position-relative">
                                            <div class="card">
                                                <img src="@Model.ExistingImages[i]" class="card-img-top" style="height: 100px; object-fit: cover;" alt="Product image" />
                                                <div class="card-body p-1 text-center">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox"
                                                               name="ImagesToDelete" value="@Model.ExistingImages[i]"
                                                               id="delete_@i" />
                                                        <label class="form-check-label small" for="delete_@i">
                                                            Удалить
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <small class="text-muted">Отметьте изображения для удаления</small>
                            </div>
                        }

                        <!-- Новые изображения -->
                        <div class="mb-3">
                            <label asp-for="NewImages" class="form-label fw-bold"></label>
                            <input asp-for="NewImages" class="form-control" type="file" multiple accept="image/*" id="imageInput" />
                            <small class="text-muted">Можно выбрать несколько новых изображений (jpg, jpeg, png, gif, webp)</small>
                            
                            <!-- Превью новых изображений -->
                            <div id="imagePreview" class="row mt-2 g-2"></div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Назад к списку
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Сохранить изменения
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Предпросмотр новых изображений
            $('#imageInput').change(function() {
                const preview = $('#imagePreview');
                preview.empty();

                const files = this.files;
                if (files.length > 0) {
                    for (let i = 0; i < files.length; i++) {
                        const file = files[i];
                        const reader = new FileReader();

                        reader.onload = function(e) {
                            preview.append(`
                                <div class="col-3">
                                    <img src="${e.target.result}" class="img-thumbnail w-100" style="height: 100px; object-fit: cover;" />
                                </div>
                            `);
                        }

                        reader.readAsDataURL(file);
                    }
                }
            });
        });
    </script>
}