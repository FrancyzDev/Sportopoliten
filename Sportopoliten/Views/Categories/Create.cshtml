@model Sportopoliten.ViewModels.CategoryViewModels.CreateCategoryViewModel

@{
    ViewData["Title"] = "Создание категории";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-white py-3 rounded-top-4">
                    <h4 class="mb-0">
                        <i class="fas fa-folder-plus me-2"></i>@ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Название категории -->
                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">
                                <i class="fas fa-tag me-2 text-primary"></i>Название категории
                            </label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Введите название категории" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <!-- Загрузка изображения -->
                        <div class="mb-4">
                            <label asp-for="Image" class="form-label fw-bold">
                                <i class="fas fa-image me-2 text-primary"></i>Изображение категории
                            </label>
                            <div class="upload-area border border-2 border-dashed rounded-3 p-4 text-center" id="uploadArea">
                                <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-3"></i>
                                <h5>Перетащите файл сюда или нажмите для выбора</h5>
                                <p class="text-muted mb-3">Рекомендуемый размер: 300x300px. Форматы: JPG, PNG, WEBP, SVG</p>
                                <input asp-for="Image" class="form-control d-none" type="file" accept="image/*" id="imageInput" />
                                <!-- Кнопка выбора файла - убираем onclick и добавляем id -->
                                <button type="button" class="btn btn-outline-primary" id="selectImageBtn">
                                    <i class="fas fa-upload me-2"></i>Выбрать файл
                                </button>
                            </div>

                            <!-- Превью изображения -->
                            <div id="imagePreview" class="mt-3 text-center" style="display: none;">
                                <img src="" class="img-thumbnail" style="max-height: 200px;" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-danger mt-2" id="removeImageBtn">
                                    <i class="fas fa-times"></i> Удалить
                                </button>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Назад к списку
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="fas fa-save me-2"></i>Создать категорию
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Ждем полной загрузки DOM
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM полностью загружен');
            
            // Получаем элементы
            const imageInput = document.getElementById('imageInput');
            const selectImageBtn = document.getElementById('selectImageBtn');
            const imagePreview = document.getElementById('imagePreview');
            const previewImg = imagePreview ? imagePreview.querySelector('img') : null;
            const removeImageBtn = document.getElementById('removeImageBtn');
            const uploadArea = document.getElementById('uploadArea');
            
            console.log('imageInput:', imageInput);
            console.log('selectImageBtn:', selectImageBtn);
            
            // Проверяем, что элементы найдены
            if (!imageInput) {
                console.error('imageInput не найден!');
                return;
            }
            
            if (!selectImageBtn) {
                console.error('selectImageBtn не найден!');
                return;
            }
            
            // Кнопка выбора файла - просто вызываем click на скрытом input
            selectImageBtn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                console.log('Кнопка нажата');
                imageInput.click(); // Это должно открыть диалог выбора файла
            });
            
            // Обработка выбора файла
            imageInput.addEventListener('change', function(e) {
                console.log('Файл выбран:', this.files);
                
                if (this.files && this.files.length > 0) {
                    const file = this.files[0];
                    const reader = new FileReader();
                    
                    reader.onload = function(e) {
                        if (previewImg && imagePreview) {
                            previewImg.src = e.target.result;
                            imagePreview.style.display = 'block';
                        }
                    }
                    
                    reader.readAsDataURL(file);
                }
            });
            
            // Удаление изображения
            if (removeImageBtn) {
                removeImageBtn.addEventListener('click', function() {
                    imageInput.value = '';
                    if (imagePreview) imagePreview.style.display = 'none';
                    if (previewImg) previewImg.src = '';
                });
            }
            
            // Drag and drop (упрощенно)
            if (uploadArea) {
                uploadArea.addEventListener('dragover', function(e) {
                    e.preventDefault();
                    this.style.backgroundColor = '#e9ecef';
                    this.style.borderColor = '#764ba2';
                });
                
                uploadArea.addEventListener('dragleave', function(e) {
                    e.preventDefault();
                    this.style.backgroundColor = '#f8f9fa';
                    this.style.borderColor = '#667eea';
                });
                
                uploadArea.addEventListener('drop', function(e) {
                    e.preventDefault();
                    this.style.backgroundColor = '#f8f9fa';
                    this.style.borderColor = '#667eea';
                    
                    const files = e.dataTransfer.files;
                    if (files.length > 0) {
                        imageInput.files = files;
                        
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            if (previewImg && imagePreview) {
                                previewImg.src = e.target.result;
                                imagePreview.style.display = 'block';
                            }
                        }
                        reader.readAsDataURL(files[0]);
                    }
                });
            }
        });
    </script>
}

@section Styles {
    <style>
        .bg-gradient-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        
        .border-dashed {
            border-style: dashed !important;
            border-width: 2px !important;
            border-color: #667eea !important;
        }
        
        .upload-area {
            transition: all 0.3s ease;
            cursor: pointer;
            background-color: #f8f9fa;
        }
        
            .upload-area:hover {
                background-color: #e9ecef;
                border-color: #764ba2 !important;
            }
        
            .upload-area i {
                transition: transform 0.3s ease;
            }
        
            .upload-area:hover i {
                transform: translateY(-5px);
            }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
        }
        
            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            }
    </style>
}