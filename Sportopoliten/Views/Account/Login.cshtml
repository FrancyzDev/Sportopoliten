@model Sportopoliten.ViewModels.AccountViewModels.LoginViewModel

@{
    ViewData["Title"] = "Вход";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-12 col-sm-8 col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h4 fw-bold mb-1">Вход</h1>
                <p class="text-muted small mb-4">Войдите в свой аккаунт Sportopoliten</p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success py-2 small">
                        <i class="fa-solid fa-circle-check me-1"></i> @TempData["SuccessMessage"]
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="mb-3">
                        <label asp-for="LoginOrEmail" class="form-label"></label>
                        <input asp-for="LoginOrEmail" class="form-control" placeholder="your@email.com или логин" autocomplete="username" />
                        <span asp-validation-for="LoginOrEmail" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                            <label asp-for="RememberMe" class="form-check-label small"></label>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark">
                            <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>Войти
                        </button>
                    </div>
                </form>

                <hr class="my-3" />

                <p class="text-center small text-muted mb-0">
                    Нет аккаунта?
                    <a asp-action="Register" class="text-dark fw-semibold">Зарегистрироваться</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}