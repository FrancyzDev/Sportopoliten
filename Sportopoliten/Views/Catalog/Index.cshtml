@model Sportopoliten.ViewModels.CatalogViewModels.CatalogViewModel
@using System.Globalization
@using Sportopoliten.ViewModels.CatalogViewModels

@{
    ViewData["Title"] = "Каталог товарів";
    Layout = "_Layout";
}

<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="bg-light py-3">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Головна</a></li>
            <li class="breadcrumb-item active">Каталог</li>
        </ol>
    </div>
</nav>

<!-- Заголовок -->
<section class="page-header py-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-5 fw-bold mb-0">Каталог товарів</h1>
                <p class="text-muted mt-2">Знайдено @Model.TotalItems товарів</p>
            </div>
            <div class="col-md-6">
                <form asp-action="Index" method="get" class="search-form">
                    <div class="input-group">
                        <input type="text" name="searchTerm" class="form-control" placeholder="Пошук товарів..." value="@Model.SearchTerm">
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Основной контент -->
<section class="catalog-content py-4">
    <div class="container">
        <div class="row">
            <!-- Фильтры (левая колонка) -->
            <div class="col-lg-3 mb-4">
                <div class="filters-card card shadow-sm">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="fas fa-filter me-2 text-primary"></i>Фільтри
                        </h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Index" method="get" id="filterForm">
                            <!-- Сохраняем текущие параметры -->
                            <input type="hidden" name="page" value="1" />
                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                            
                            <!-- Фильтр по категориям -->
                            <div class="filter-section mb-4">
                                <h6 class="fw-bold mb-3">Категорії</h6>
                                <div class="category-list">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="categoryId" 
                                               id="catAll" value="" @(Model.SelectedCategoryId == null ? "checked" : "")>
                                        <label class="form-check-label" for="catAll">
                                            Всі категорії
                                        </label>
                                    </div>
                                    @foreach (var category in Model.Categories)
                                    {
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="radio" name="categoryId" 
                                                   id="cat_@category.Id" value="@category.Id"
                                                   @(Model.SelectedCategoryId == category.Id ? "checked" : "")>
                                            <label class="form-check-label d-flex justify-content-between" for="cat_@category.Id">
                                                <span>@category.Title</span>
                                                <span class="badge bg-light text-dark">@category.ProductCount</span>
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Фильтр по цене -->
                            <div class="filter-section mb-4">
                                <h6 class="fw-bold mb-3">Ціна</h6>
                                <div class="price-range">
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text">₴</span>
                                                <input type="number" name="minPrice" class="form-control" 
                                                       placeholder="Від" value="@Model.MinPrice" 
                                                       min="@Model.PriceRangeMin" max="@Model.PriceRangeMax">
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text">₴</span>
                                                <input type="number" name="maxPrice" class="form-control" 
                                                       placeholder="До" value="@Model.MaxPrice"
                                                       min="@Model.PriceRangeMin" max="@Model.PriceRangeMax">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Сортировка -->
                            <div class="filter-section mb-4">
                                <h6 class="fw-bold mb-3">Сортування</h6>
                                <select name="sortBy" class="form-select">
                                    @{
                                        var currentSortBy = Model.SortBy ?? "";
                                    }
                                    <option value="newest" selected="@(currentSortBy == "newest")">Новинки</option>
                                    <option value="price_asc" selected="@(currentSortBy == "price_asc")">Ціна (від дешевих)</option>
                                    <option value="price_desc" selected="@(currentSortBy == "price_desc")">Ціна (від дорогих)</option>
                                    <option value="name_asc" selected="@(currentSortBy == "name_asc")">Назва (А-Я)</option>
                                    <option value="name_desc" selected="@(currentSortBy == "name_desc")">Назва (Я-А)</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search me-2"></i>Застосувати
                            </button>
                            
                            <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                                <i class="fas fa-times me-2"></i>Скинути
                            </a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Товары (правая колонка) -->
            <div class="col-lg-9">
                @if (Model.Items.Any())
                {
                    <div class="row g-4">
                        @foreach (var product in Model.Items)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="product-card card h-100 border-0 shadow-sm">
                                    <a asp-action="Product" asp-route-id="@product.Id" class="text-decoration-none">
                                        <div class="product-image position-relative">
                                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Title" 
                                                 style="height: 200px; object-fit: cover;">
                                            @if (product.Price < 1000)
                                            {
                                                <span class="badge bg-success position-absolute top-0 end-0 m-2">-20%</span>
                                            }
                                        </div>
                                        <div class="card-body">
                                            <p class="text-muted small mb-1">@product.CategoryName</p>
                                            <h6 class="card-title text-dark fw-bold mb-2">@product.Title</h6>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="text-primary fw-bold h5 mb-0">@product.Price.ToString("C", new CultureInfo("uk-UA"))</span>
                                                <button class="btn btn-sm btn-primary rounded-circle add-to-cart" 
                                                        onclick="addToCart(@product.Id, event)">
                                                    <i class="fas fa-shopping-cart"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Пагинация -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-5">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage - 1, Model)">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                                
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@GetPageUrl(i, Model)">@i</a>
                                    </li>
                                }
                                
                                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage + 1, Model)">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <i class="fas fa-box-open fa-4x text-muted"></i>
                        </div>
                        <h4 class="text-muted mb-3">Товари не знайдені</h4>
                        <p class="text-muted">Спробуйте змінити параметри пошуку</p>
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-redo-alt me-2"></i>Скинути фільтри
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@functions {
    string GetPageUrl(int page, CatalogViewModel model)
    {
        var query = new List<string>();
        
        if (!string.IsNullOrEmpty(model.SearchTerm))
            query.Add($"searchTerm={Uri.EscapeDataString(model.SearchTerm)}");
        
        if (model.SelectedCategoryId.HasValue)
            query.Add($"categoryId={model.SelectedCategoryId}");
        
        if (model.MinPrice.HasValue)
            query.Add($"minPrice={model.MinPrice}");
        
        if (model.MaxPrice.HasValue)
            query.Add($"maxPrice={model.MaxPrice}");
        
        if (!string.IsNullOrEmpty(model.SortBy))
            query.Add($"sortBy={model.SortBy}");
        
        query.Add($"page={page}");
        
        return Url.Action("Index", "Catalog") + "?" + string.Join("&", query);
    }
}

@section Scripts {
    <script>
        function addToCart(productId, event) {
            event.preventDefault();
            event.stopPropagation();
            
            // Здесь будет логика добавления в корзину
            alert('Товар додано до кошика!');
        }
        
        // Автоматическое применение фильтров при изменении
        $(document).ready(function() {
            $('input[name="categoryId"]').change(function() {
                $('#filterForm').submit();
            });
            
            $('select[name="sortBy"]').change(function() {
                $('#filterForm').submit();
            });
        });
    </script>
}

@section Styles {
    <style>
        .product-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
            border-radius: 12px;
            overflow: hidden;
        }
        
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
        }
        
        .product-image {
            overflow: hidden;
        }
        
        .product-image img {
            transition: transform 0.5s ease;
        }
        
        .product-card:hover .product-image img {
            transform: scale(1.05);
        }
        
        .add-to-cart {
            width: 35px;
            height: 35px;
            padding: 0;
            line-height: 35px;
            text-align: center;
        }
        
        .filters-card {
            border: none;
            border-radius: 12px;
            position: sticky;
            top: 20px;
        }
        
        .filter-section:not(:last-child) {
            border-bottom: 1px solid #eee;
            padding-bottom: 1rem;
        }
        
        .category-list {
            max-height: 300px;
            overflow-y: auto;
        }
        
        .category-list::-webkit-scrollbar {
            width: 5px;
        }
        
        .category-list::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        
        .category-list::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 5px;
        }
        
        .category-list::-webkit-scrollbar-thumb:hover {
            background: #555;
        }
        
        .page-link {
            color: #667eea;
            border: none;
            margin: 0 3px;
            border-radius: 8px;
        }
        
        .page-item.active .page-link {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
        }
        
        .breadcrumb {
            background: transparent;
        }
        
        .breadcrumb-item a {
            color: #667eea;
            text-decoration: none;
        }
        
        .breadcrumb-item.active {
            color: #6c757d;
        }
    </style>
}