@model Sportopoliten.ViewModels.CatalogViewModels.CatalogViewModel
@using System.Globalization
@using Sportopoliten.ViewModels.CatalogViewModels

@{
    ViewData["Title"] = "Каталог товаров";
    Layout = "_Layout";
}

<nav aria-label="breadcrumb" class="bg-light py-3">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Главная</a></li>
            <li class="breadcrumb-item active">Каталог</li>
        </ol>
    </div>
</nav>

<section class="page-header py-4">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-5 fw-bold mb-0">Каталог товаров</h1>
                <p class="text-muted mt-2">Найдено @Model.TotalItems товаров</p>
            </div>
            <div class="col-md-6">
                <form asp-action="Index" method="get" class="search-form">
                    <div class="input-group">
                        <input type="text" name="searchTerm" class="form-control" placeholder="Поиск товаров..." value="@Model.SearchTerm">
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="catalog-content py-4">
    <div class="container">
        <div class="row">
            <div class="col-lg-3 mb-4">
                <div class="filters-card card shadow-sm">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">
                            <i class="fas fa-filter me-2 text-primary"></i>Фильтры
                        </h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Index" method="get" id="filterForm">
                            <input type="hidden" name="page" value="1" />
                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                            
                            <div class="filter-section mb-4">
                                <h6 class="fw-bold mb-3">Категории</h6>
                                <div class="category-list">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="categoryId" 
                                               id="catAll" value="" @(Model.SelectedCategoryId == null ? "checked" : "")>
                                        <label class="form-check-label" for="catAll">
                                            <span>Все категории</span>
                                            <span class="badge bg-light text-dark">@Model.Categories.Sum(c => c.ProductCount)</span>
                                        </label>
                                    </div>
                                    @foreach (var category in Model.Categories)
                                    {
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="radio" name="categoryId" 
                                                   id="cat_@category.Id" value="@category.Id"
                                                   @(Model.SelectedCategoryId == category.Id ? "checked" : "")>
                                            <label class="form-check-label d-flex justify-content-between" for="cat_@category.Id">
                                                <span>@category.Title</span>
                                                <span class="badge bg-light text-dark">@category.ProductCount</span>
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="filter-section mb-4">
                                <h6 class="fw-bold mb-3">Цена</h6>
                                <div class="price-range">
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text">₴</span>
                                                <input type="number" name="minPrice" class="form-control" 
                                                       placeholder="От" value="@Model.MinPrice" 
                                                       min="@Model.PriceRangeMin" max="@Model.PriceRangeMax">
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text">₴</span>
                                                <input type="number" name="maxPrice" class="form-control" 
                                                       placeholder="До" value="@Model.MaxPrice"
                                                       min="@Model.PriceRangeMin" max="@Model.PriceRangeMax">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="filter-section mb-4">
                                <h6 class="fw-bold mb-3">Сортировка</h6>
                                <select name="sortBy" class="form-select">
                                    @{
                                        var currentSortBy = Model.SortBy ?? "";
                                    }
                                    <option value="newest" selected="@(currentSortBy == "newest")">Новинки</option>
                                    <option value="price_asc" selected="@(currentSortBy == "price_asc")">Цена (от дешевых)</option>
                                    <option value="price_desc" selected="@(currentSortBy == "price_desc")">Цена (от дорогих)</option>
                                    <option value="name_asc" selected="@(currentSortBy == "name_asc")">Название (А-Я)</option>
                                    <option value="name_desc" selected="@(currentSortBy == "name_desc")">Название (Я-А)</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search me-2"></i>Применить
                            </button>
                            
                            <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                                <i class="fas fa-times me-2"></i>Сбросить
                            </a>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                @if (Model.Items.Any())
                {
                    <div class="row g-4">
                        @foreach (var product in Model.Items)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="product-card card h-100 border-0 shadow-sm">
                                    <a asp-action="Product" asp-route-id="@product.Id" class="text-decoration-none">
                                        <div class="product-image position-relative">
                                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Title" style="height: 200px; object-fit: cover;">
                                        </div>
                                        <div class="card-body">
                                            <p class="text-muted small mb-1">@product.CategoryName</p>
                                            <h6 class="card-title text-dark fw-bold mb-2">@product.Title</h6>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="text-primary fw-bold h5 mb-0">@product.Price</span>
                                                <button class="btn btn-sm btn-primary rounded-circle view-product" 
                                                        onclick="window.location.href='@Url.Action("Product", "Catalog", new { id = product.Id })'">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-5">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage - 1, Model)">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                                
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@GetPageUrl(i, Model)">@i</a>
                                    </li>
                                }
                                
                                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage + 1, Model)">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <i class="fas fa-box-open fa-4x text-muted"></i>
                        </div>
                        <h4 class="text-muted mb-3">Товары не найдены</h4>
                        <p class="text-muted">Попробуйте изменить параметры поиска</p>
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-redo-alt me-2"></i>Сбросить фильтры
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@functions {
    string GetPageUrl(int page, CatalogViewModel model)
    {
        var query = new List<string>();
        
        if (!string.IsNullOrEmpty(model.SearchTerm))
            query.Add($"searchTerm={Uri.EscapeDataString(model.SearchTerm)}");
        
        if (model.SelectedCategoryId.HasValue)
            query.Add($"categoryId={model.SelectedCategoryId}");
        
        if (model.MinPrice.HasValue)
            query.Add($"minPrice={model.MinPrice}");
        
        if (model.MaxPrice.HasValue)
            query.Add($"maxPrice={model.MaxPrice}");
        
        if (!string.IsNullOrEmpty(model.SortBy))
            query.Add($"sortBy={model.SortBy}");
        
        query.Add($"page={page}");
        
        return Url.Action("Index", "Catalog") + "?" + string.Join("&", query);
    }
}

@section Scripts {
    <script>
        $(document).ready(function() {
            $('input[name="categoryId"]').change(function() {
                $('#filterForm').submit();
            });
            
            $('select[name="sortBy"]').change(function() {
                $('#filterForm').submit();
            });
        });
    </script>
}

@section Styles {
    <style>
        .product-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
            border-radius: 12px;
            overflow: hidden;
        }
        
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
        }
        
        .product-image {
            overflow: hidden;
        }
        
        .product-image img {
            transition: transform 0.5s ease;
        }
        
        .product-card:hover .product-image img {
            transform: scale(1.05);
        }
        
        .view-product {
            width: 35px;
            height: 35px;
            padding: 0;
            line-height: 35px;
            text-align: center;
        }
        
        .filters-card {
            border: none;
            border-radius: 16px;
            position: sticky;
            top: 20px;
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
            transition: all 0.3s ease;
        }

        .filters-card:hover {
            box-shadow: 0 15px 40px rgba(102, 126, 234, 0.1) !important;
        }

        .filters-card .card-header {
            border-bottom: 1px solid rgba(0,0,0,0.05);
            background: white;
            border-radius: 16px 16px 0 0 !important;
            padding: 1.2rem 1.5rem;
        }

        .filters-card .card-header h5 {
            font-size: 1.1rem;
            font-weight: 600;
            color: #333;
        }

        .filters-card .card-body {
            padding: 1.5rem;
        }

        .filter-section:not(:last-child) {
            border-bottom: 1px solid #eee;
            padding-bottom: 1rem;
        }

        .filter-section h6 {
            font-size: 0.95rem;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 1rem !important;
            position: relative;
            padding-left: 12px;
        }

        .filter-section h6::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 2px;
        }

        .category-list .form-check {
            padding-left: 0;
            margin-bottom: 0.5rem !important;
        }

        .category-list .form-check-input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .category-list .form-check-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.6rem 1rem;
            background-color: #f8f9fa;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 2px solid transparent;
            font-weight: 500;
        }

        .category-list .form-check-label:hover {
            background-color: #e9ecef;
            transform: translateX(5px);
        }

        .category-list .form-check-input:checked + .form-check-label {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-color: #764ba2;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        }

        .category-list .form-check-input:checked + .form-check-label .badge {
            background-color: white !important;
            color: #667eea !important;
        }

        .category-list .badge {
            font-size: 0.75rem;
            padding: 0.4rem 0.8rem;
            border-radius: 20px;
            transition: all 0.2s ease;
        }

        #catAll:checked + .form-check-label {
            background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        }

        .category-list .form-check {
            animation: slideIn 0.3s ease;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-10px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .price-range .input-group {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .price-range .input-group-text {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            font-weight: 600;
        }

        .price-range .form-control {
            border: 1px solid #e9ecef;
            border-left: none;
            font-size: 0.9rem;
            padding: 0.5rem;
        }

        .price-range .form-control:focus {
            border-color: #667eea;
            box-shadow: none;
        }

        .page-link {
            color: #667eea;
            border: none;
            margin: 0 3px;
            border-radius: 8px;
        }
        
        .page-item.active .page-link {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
        }
        
        .breadcrumb {
            background: transparent;
        }
        
        .breadcrumb-item a {
            color: #667eea;
            text-decoration: none;
        }
        
        .breadcrumb-item.active {
            color: #6c757d;
        }

        .category-list {
            max-height: 300px;
            overflow-y: auto;
            padding-right: 5px;
        }
        
        .category-list::-webkit-scrollbar {
            width: 5px;
        }
        
        .category-list::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        
        .category-list::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 10px;
        }
        
        .category-list::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-outline-secondary {
            border: 1px solid #dee2e6;
            transition: all 0.3s ease;
        }

        .btn-outline-secondary:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
    </style>
}