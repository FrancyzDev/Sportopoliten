@model Sportopoliten.BLL.DTO.User.UserDTO

@{
    ViewData["Title"] = "Детали пользователя";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-user-circle me-2"></i>@ViewData["Title"]: @Model.FullName
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    @if (Model.IsAdmin)
                                    {
                                        <span class="badge bg-danger fs-6">
                                            <i class="fas fa-user-shield me-1"></i> Администратор
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary fs-6">
                                            <i class="fas fa-user me-1"></i> Пользователь
                                        </span>
                                    }
                                </div>
                                <div>
                                    <small class="text-muted">
                                        <i class="fas fa-calendar-alt me-1"></i> Зарегистрирован: @Model.CreatedAt.ToString("dd MMMM yyyy, HH:mm")
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="info-card">
                                <div class="info-label">
                                    <i class="fas fa-id-badge text-primary"></i> ID пользователя
                                </div>
                                <div class="info-value">
                                    <h5 class="mb-0">#@Model.Id</h5>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <div class="info-card">
                                <div class="info-label">
                                    <i class="fas fa-user text-primary"></i> ФИО
                                </div>
                                <div class="info-value">
                                    <h5 class="mb-0">@Model.FullName</h5>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <div class="info-card">
                                <div class="info-label">
                                    <i class="fas fa-at text-primary"></i> Логин
                                </div>
                                <div class="info-value">
                                    <h5 class="mb-0">@Model.Login</h5>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <div class="info-card">
                                <div class="info-label">
                                    <i class="fas fa-envelope text-primary"></i> Email
                                </div>
                                <div class="info-value">
                                    <h5 class="mb-0">
                                        <a href="mailto:@Model.Email" class="text-decoration-none">
                                            @Model.Email
                                        </a>
                                    </h5>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <div class="info-card">
                                <div class="info-label">
                                    <i class="fas fa-phone text-primary"></i> Телефон
                                </div>
                                <div class="info-value">
                                    <h5 class="mb-0">
                                        <a href="tel:@Model.Phone" class="text-decoration-none">
                                            @Model.Phone
                                        </a>
                                    </h5>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <div class="info-card">
                                <div class="info-label">
                                    <i class="fas fa-shopping-cart text-primary"></i> Корзина
                                </div>
                                <div class="info-value">
                                    <h5 class="mb-0">
                                        <span class="badge bg-info">ID корзины: @Model.CartId</span>
                                    </h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.Cart != null)
                    {
                        <div class="mt-4">
                            <h5 class="mb-3">
                                <i class="fas fa-shopping-bag me-2"></i>Товары в корзине
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Товар</th>
                                            <th>Количество</th>
                                            <th>Цена</th>
                                            <th>Сумма</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Cart.Items != null && Model.Cart.Items.Any())
                                        {
                                            foreach (var item in Model.Cart.Items)
                                            {
                                                <tr>
                                                    <td>@item.ProductName</td>
                                                    <td>@item.Count</td>
                                                    <td>@item.Price.ToString("C")</td>
                                                    <td>@((item.Count * (item?.Price ?? 0)).ToString("C"))</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center text-muted">
                                                    <i class="fas fa-box-open me-1"></i> Корзина пуста
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between">
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Назад к списку
                        </a>
                        <div>
                            <button type="button" class="btn btn-danger me-2" onclick="confirmDelete(@Model.Id, '@Model.FullName')">
                                <i class="fas fa-trash me-1"></i> Удалить
                            </button>
                            <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="fas fa-edit me-1"></i> Редактировать
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal для подтверждения удаления -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Подтверждение удаления
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Вы уверены, что хотите удалить пользователя <strong id="deleteUserName"></strong>?</p>
                <p class="text-danger">Это действие невозможно отменить! Все данные пользователя будут удалены.</p>
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle me-2"></i>
                    <small>Вместе с пользователем будут удалены: корзина, история заказов и все связанные данные.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <form id="deleteForm" method="post" asp-area="Admin" asp-controller="Users" asp-action="Delete">
                    <input type="hidden" id="deleteUserId" name="id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i> Удалить
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, userName) {
            document.getElementById('deleteUserName').textContent = userName;
            document.getElementById('deleteUserId').value = id;
            const deleteForm = document.getElementById('deleteForm');
            deleteForm.action = `/admin/users/delete/${id}`;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}

<style>
    .info-card {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 15px;
        transition: all 0.3s ease;
        border-left: 4px solid #0d6efd;
    }
    
        .info-card:hover {
            background: #e9ecef;
            transform: translateX(5px);
        }
    
    .info-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        margin-bottom: 8px;
    }
    
    .info-value {
        font-size: 1rem;
    }
    
    .badge {
        padding: 8px 12px;
        border-radius: 6px;
    }
    
    .card {
        border: none;
        border-radius: 10px;
    }
    
    .card-header {
        border-radius: 10px 10px 0 0;
    }
    
    .table th {
        border-top: none;
    }
    
    hr {
        opacity: 0.1;
    }
</style>