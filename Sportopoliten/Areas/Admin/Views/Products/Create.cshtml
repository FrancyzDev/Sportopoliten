@model Sportopoliten.Areas.Admin.ViewModels.Products.CreateProductViewModel

@{
    ViewData["Title"] = "Создание товара";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-box-open me-2"></i>@ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-area="Admin" asp-controller="Products" asp-action="Create" method="post" id="createProductForm">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Title" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                    <input asp-for="Title" class="form-control" placeholder="Введите название товара" />
                                </div>
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-align-left"></i></span>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Введите описание товара"></textarea>
                            </div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-dollar-sign"></i></span>
                                    <input asp-for="Price" class="form-control" placeholder="0.00" step="0.01" />
                                    <span class="input-group-text">₴</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-folder"></i></span>
                                    <select asp-for="CategoryId" class="form-select">
                                        <option value="">-- Выберите категорию --</option>
                                        @if (ViewBag.Categories != null)
                                        {
                                            foreach (var category in ViewBag.Categories)
                                            {
                                                <option value="@category.Value">@category.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Поле для ввода URL изображений -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-images me-2"></i>URL изображений товара
                            </label>
                            <div id="imagesContainer">
                                <div class="input-group mb-2 image-url-group">
                                    <span class="input-group-text"><i class="fas fa-link"></i></span>
                                    <input type="url" name="ImageUrls" class="form-control" placeholder="https://example.com/image.jpg" />
                                    <button type="button" class="btn btn-danger remove-image-btn" style="display: none;">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>
                            <button type="button" id="addImageBtn" class="btn btn-secondary btn-sm mt-2">
                                <i class="fas fa-plus"></i> Добавить еще URL
                            </button>
                            <small class="form-text text-muted d-block mt-2">
                                <i class="fas fa-info-circle"></i> Введите URL-адреса изображений товара. Можно добавить несколько ссылок.
                            </small>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Назад к списку
                            </a>
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                <i class="fas fa-save me-1"></i> Создать товар
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 10px;
    }
    
    .card-header {
        border-radius: 10px 10px 0 0;
    }
    
    .input-group-text {
        background-color: #f8f9fa;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #80bdff;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
    }
    
    .btn-primary {
        transition: all 0.2s ease;
    }
    
        .btn-primary:active {
            transform: scale(0.98);
        }
    
    .alert {
        animation: fadeIn 0.3s ease-in;
    }
    
    .field-validation-error {
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
    }
    
    .input-validation-error {
        border-color: #dc3545 !important;
    }
    
        .input-validation-error:focus {
            border-color: #dc3545 !important;
            box-shadow: 0 0 0 0.2rem rgba(220,53,69,.25) !important;
        }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Добавление нового поля для URL
        const addImageBtn = document.getElementById('addImageBtn');
        const imagesContainer = document.getElementById('imagesContainer');
        
        function updateRemoveButtons() {
            const groups = document.querySelectorAll('.image-url-group');
            groups.forEach((group, index) => {
                const removeBtn = group.querySelector('.remove-image-btn');
                if (groups.length === 1) {
                    removeBtn.style.display = 'none';
                } else {
                    removeBtn.style.display = 'flex';
                }
            });
        }
        
        if (addImageBtn) {
            addImageBtn.addEventListener('click', function() {
                const newGroup = document.createElement('div');
                newGroup.className = 'input-group mb-2 image-url-group';
                newGroup.innerHTML = `
                    <span class="input-group-text"><i class="fas fa-link"></i></span>
                    <input type="url" name="ImageUrls" class="form-control" placeholder="https://example.com/image.jpg" />
                    <button type="button" class="btn btn-danger remove-image-btn">
                        <i class="fas fa-times"></i>
                    </button>
                `;
                imagesContainer.appendChild(newGroup);
                updateRemoveButtons();
            });
        }
        
        // Удаление поля
        imagesContainer.addEventListener('click', function(e) {
            const btn = e.target.closest('.remove-image-btn');
            if (btn) {
                btn.closest('.image-url-group').remove();
                updateRemoveButtons();
            }
        });
        
        // Инициализация - скрываем кнопку удаления если только одно поле
        updateRemoveButtons();
    });
</script>