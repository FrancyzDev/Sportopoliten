@model Sportopoliten.ViewModels.AccountViewModels.EditProfileViewModel
@{
    ViewData["Title"] = "Редактирование профиля";
    Layout = "_Layout";
}

<nav aria-label="breadcrumb" class="bg-light py-3">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Главная</a></li>
            <li class="breadcrumb-item"><a asp-controller="Account" asp-action="Index">Личный кабинет</a></li>
            <li class="breadcrumb-item active">Редактирование профиля</li>
        </ol>
    </div>
</nav>

<section class="edit-profile-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h4 class="mb-0">
                            <i class="fas fa-edit me-2 text-primary"></i>Редактирование профиля
                        </h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="EditProfile" method="post">
                            @Html.AntiForgeryToken()
                            
                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                            }
                            
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label asp-for="FullName" class="form-label fw-bold">ФИО</label>
                                    <input asp-for="FullName" class="form-control" placeholder="Введите ваше полное имя">
                                        <span asp-validation-for="FullName" class="text-danger"></span>
                                    </div>
                                
                                    <div class="col-md-12 mb-3">
                                        <label asp-for="Email" class="form-label fw-bold">Email</label>
                                        <input asp-for="Email" class="form-control" placeholder="example@mail.com">
                                            <span asp-validation-for="Email" class="text-danger"></span>
                                        </div>
                                
                                        <div class="col-md-12 mb-3">
                                            <label asp-for="Phone" class="form-label fw-bold">Телефон</label>
                                            <input asp-for="Phone" class="form-control" placeholder="+38 (0XX) XXX-XX-XX">
                                                <span asp-validation-for="Phone" class="text-danger"></span>
                                            </div>
                                        </div>
                            
                                        <hr>
                            
                                        <div class="d-flex justify-content-between">
                                            <a asp-action="Index" class="btn btn-outline-secondary">
                                                <i class="fas fa-arrow-left me-2"></i>Назад
                                            </a>
                                            <button type="submit" class="btn btn-primary">
                                                <i class="fas fa-save me-2"></i>Сохранить изменения
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            @section Styles {
                <style>
                    .edit-profile-section .card {
                        border-radius: 16px;
                        overflow: hidden;
                    }
        
                    .edit-profile-section .card-header {
                        border-bottom: 1px solid rgba(0,0,0,0.05);
                    }
        
                    .edit-profile-section .form-control {
                        border: 1px solid #e9ecef;
                        border-radius: 10px;
                        padding: 0.6rem 1rem;
                        transition: all 0.3s ease;
                    }
        
                        .edit-profile-section .form-control:focus {
                            border-color: #667eea;
                            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.1);
                        }
        
                    .edit-profile-section .form-label {
                        font-size: 0.85rem;
                        margin-bottom: 0.5rem;
                        color: #555;
                    }
        
                    .btn-primary {
                        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                        border: none;
                        transition: all 0.3s ease;
                    }
        
                        .btn-primary:hover {
                            transform: translateY(-2px);
                            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
                        }
        
                    .btn-outline-secondary:hover {
                        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                        border-color: transparent;
                        color: white;
                        transform: translateY(-2px);
                    }
        
                    .breadcrumb {
                        background: transparent;
                    }
        
                    .breadcrumb-item a {
                        color: #667eea;
                        text-decoration: none;
                    }
        
                    .breadcrumb-item.active {
                        color: #6c757d;
                    }
                </style>
            }