@model Sportopoliten.BLL.DTO.Category.CategoryDTO

@{
    ViewData["Title"] = "Удаление категории";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-lg border-0 rounded-4 border-danger">
                <div class="card-header bg-danger text-white py-3 rounded-top-4">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>@ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-4 text-center mb-3">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" class="img-thumbnail" style="max-height: 150px;" alt="@Model.Title" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center p-4">
                                    <i class="fas fa-folder fa-4x text-muted"></i>
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <table class="table table-bordered">
                                <tr>
                                    <th style="width: 30%">ID</th>
                                    <td>@Model.Id</td>
                                </tr>
                                <tr>
                                    <th>Название</th>
                                    <td>@Model.Title</td>
                                </tr>
                                <tr>
                                    <th>Количество товаров</th>
                                    <td>
                                        <span class="badge bg-info">@Model.ProductsCount</span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-arrow-left me-2"></i>Назад к списку
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg px-5">
                                <i class="fas fa-trash me-2"></i>Подтвердить удаление
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>