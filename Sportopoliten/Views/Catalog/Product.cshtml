@model Sportopoliten.ViewModels.ProductViewModels.DetailProductViewModel
@using System.Globalization

@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<nav aria-label="breadcrumb" class="bg-light py-3">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Главная</a></li>
            <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index">Каталог</a></li>
            <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </div>
</nav>

<section class="product-details py-5">
    <div class="container">
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="product-gallery">
                    <div class="main-image mb-3">
                        <img id="mainImage" src="@(Model.Images.Any() ? Model.Images[0] : "/images/no-image.jpg")"
                             class="img-fluid rounded" alt="@Model.Title" style="width: 100%; height: 500px; object-fit: cover;">
                    </div>
                    @if (Model.Images.Count > 1)
                    {
                        <div class="thumbnail-images d-flex gap-2">
                            @foreach (var image in Model.Images)
                            {
                                <img src="@image"
                                     class="thumbnail img-thumbnail"
                                     alt="Thumbnail"
                                     style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;"
                                     onclick="changeMainImage(this.src)">
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-6">
                <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>
                
                <div class="mb-3">
                    <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-decoration-none">
                        <i class="fas fa-tag me-1"></i>@Model.CategoryName
                    </a>
                </div>

                <div class="price mb-4">
                    <span class="display-6 fw-bold text-primary">@Model.Price ₴</span>
                </div>

                <div class="description mb-4">
                    <h5>Описание товара:</h5>
                    <p class="text-muted">@(string.IsNullOrEmpty(Model.Description) ? "Описание отсутствует" : Model.Description)</p>
                </div>

                <div class="size-selector mb-4">
                    <label class="form-label fw-bold">Размер:</label>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var size in Model.AvailableSizes)
                        {
                            <button type="button" class="btn btn-outline-primary size-btn" data-size="@size">
                                @size
                            </button>
                        }
                    </div>
                </div>

                <div class="quantity-selector mb-4">
                    <label class="form-label fw-bold">Количество:</label>
                    <div class="input-group" style="width: 150px;">
                        <button class="btn btn-outline-secondary" type="button" id="decrementBtn">-</button>
                        <input type="number" id="quantity" class="form-control text-center" value="1" min="1" max="99">
                        <button class="btn btn-outline-secondary" type="button" id="incrementBtn">+</button>
                    </div>
                </div>

                <div class="actions">
                    <button class="btn btn-primary btn-lg w-100 mb-3" id="addToCartBtn">
                        <i class="fas fa-shopping-cart me-2"></i>Добавить в корзину
                    </button>
                    <button class="btn btn-outline-secondary w-100" id="wishlistBtn">
                        <i class="fas fa-heart me-2"></i>Добавить в желания
                    </button>
                </div>

                <div class="additional-info mt-4 pt-3 border-top">
                    <div class="row g-3">
                        <div class="col-6">
                            <small class="text-muted">
                                <i class="fas fa-truck me-1"></i> Бесплатная доставка от 2000₴
                            </small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">
                                <i class="fas fa-undo me-1"></i> Возврат 14 дней
                            </small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">
                                <i class="fas fa-shield-alt me-1"></i> Гарантия качества
                            </small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">
                                <i class="fas fa-credit-card me-1"></i> Оплата частями
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let selectedSize = null;
        
        // Выбор размера
        document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', function() {
        document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        selectedSize = this.dataset.size;
        });
        });
        
        // Добавление в корзину с использованием глобальной функции
        document.getElementById('addToCartBtn').addEventListener('click', async function() {
        if (!selectedSize) {
        Swal.fire({
        icon: 'warning',
        title: 'Выберите размер',
        text: 'Пожалуйста, выберите размер товара',
        confirmButtonText: 'Хорошо'
        });
        return;
        }

        const quantity = parseInt(document.getElementById('quantity').value) || 1;
        const productId = @Model.Id;
        const button = this;
        const productName = '@Html.Raw(Model.Title)';
            
        const originalHtml = button.innerHTML;
        button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Добавляется...';
        button.disabled = true;
            
        try {
        const params = new URLSearchParams();
        params.append('productId', productId);
        params.append('count', quantity);
        params.append('size', selectedSize);
                
        const response = await fetch('/Cart/AddToCart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: params
        });
                
        const result = await response.json();
                
        if (result.success) {
        // Показываем уведомление об успехе
        Swal.fire({
        icon: 'success',
        title: 'Добавлено!',
        text: `${productName} (${selectedSize}) - ${quantity} шт.`,
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 2000,
        timerProgressBar: true
        });
                    
        // Обновляем счетчик корзины
        if (typeof window.updateCartCounter === 'function') {
        window.updateCartCounter();
        }
                    
        button.innerHTML = '<i class="fas fa-check me-2"></i>Добавлено!';
        setTimeout(() => {
        button.innerHTML = originalHtml;
        button.disabled = false;
        }, 1500);
        } else {
        if (result.redirectToLogin) {
        window.location.href = '/Account/Login';
        } else {
        Swal.fire({
        icon: 'error',
        title: 'Ошибка',
        text: result.message || 'Не удалось добавить товар в корзину'
        });
        }
        button.innerHTML = originalHtml;
        button.disabled = false;
        }
        } catch (error) {
        console.error('Error:', error);
        Swal.fire({
        icon: 'error',
        title: 'Ошибка',
        text: 'Не удалось добавить товар в корзину'
        });
        button.innerHTML = originalHtml;
        button.disabled = false;
        }
        });
        
        // Управление количеством
        function decrementQuantity() {
        let qty = parseInt(document.getElementById('quantity').value);
        if (qty > 1) {
        document.getElementById('quantity').value = qty - 1;
        }
        }
        
        function incrementQuantity() {
        let qty = parseInt(document.getElementById('quantity').value);
        if (qty < 99) {
        document.getElementById('quantity').value = qty + 1;
        }
        }
        
        document.getElementById('decrementBtn').addEventListener('click', decrementQuantity);
        document.getElementById('incrementBtn').addEventListener('click', incrementQuantity);
        
        // Смена главного изображения
        function changeMainImage(src) {
        document.getElementById('mainImage').src = src;
        }
        
        // Добавление в желания
        document.getElementById('wishlistBtn').addEventListener('click', function() {
        Swal.fire({
        icon: 'info',
        title: 'Скоро будет доступно',
        text: 'Функция списка желаний появится в ближайшее время',
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 2000
        });
        });
        
        // Обновление счетчика корзины при загрузке страницы
        if (typeof window.updateCartCounter === 'function') {
        window.updateCartCounter();
        }
    </script>
}

@section Styles {
    <style>
        .size-btn.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: transparent;
        }
        
        .size-btn:hover {
        transform: translateY(-2px);
        }
        
        .thumbnail {
        transition: transform 0.2s ease;
        }
        
        .thumbnail:hover {
        transform: scale(1.05);
        border-color: #667eea;
        }
        
        .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        transition: all 0.3s ease;
        }
        
        .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        
        .btn-outline-secondary:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: transparent;
        color: white;
        transform: translateY(-2px);
        }
        
        .breadcrumb {
        background: transparent;
        }
        
        .breadcrumb-item a {
        color: #667eea;
        text-decoration: none;
        }
        
        .breadcrumb-item.active {
        color: #6c757d;
        }
        
        .quantity-selector .input-group {
        flex-wrap: nowrap;
        }
        
        .quantity-selector .form-control {
        border: 1px solid #e9ecef;
        text-align: center;
        }
        
        .quantity-selector .btn-outline-secondary {
        border-color: #dee2e6;
        }
    </style>
}