@using Sportopoliten.Extensions
@model Sportopoliten.DAL.Entities.Order
@{
    ViewData["Title"] = "Заказ оформлен";
    Layout = "_Layout";
}

<nav aria-label="breadcrumb" class="bg-light py-3">
    <div class="container">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Главная</a></li>
            <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index">Корзина</a></li>
            <li class="breadcrumb-item active">Заказ оформлен</li>
        </ol>
    </div>
</nav>

<section class="success-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body py-5">
                        <div class="success-icon mb-4">
                            <i class="fas fa-check-circle fa-5x text-success"></i>
                        </div>
                        
                        <h1 class="display-4 fw-bold mb-3">Заказ успешно оформлен!</h1>
                        
                        <p class="lead text-muted mb-4">
                            Спасибо за покупку! Номер вашего заказа: <strong class="text-primary">#@Model.Id</strong>
                        </p>
                        
                        <div class="order-info bg-light rounded-3 p-4 mb-4">
                            <div class="row">
                                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                                    <small class="text-muted text-uppercase">Дата заказа</small>
                                    <p class="fw-bold mb-0">@Model.OrderDate.ToKyivTime().ToString("dd.MM.yyyy HH:mm")</p>
                                </div>
                                <div class="col-md-6 text-center text-md-start">
                                    <small class="text-muted text-uppercase">Сумма заказа</small>
                                    <p class="fw-bold text-primary mb-0">@Model.TotalAmount ₴</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-info mb-4">
                            <i class="fas fa-envelope me-2"></i>
                            Подтверждение заказа отправлено на вашу электронную почту <strong>@Model.Email</strong>
                        </div>
                        
                        <div class="d-flex flex-wrap justify-content-center gap-3">
                            <a asp-controller="Account" asp-action="Orders" class="btn btn-primary btn-lg">
                                <i class="fas fa-list me-2"></i>Мои заказы
                            </a>
                            <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-store me-2"></i>Продолжить покупки
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2 text-primary"></i>Что дальше?
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <div class="text-center">
                                    <div class="step-icon mb-2">
                                        <i class="fas fa-envelope-open-text fa-2x text-primary"></i>
                                    </div>
                                    <h6>Подтверждение</h6>
                                    <p class="small text-muted">Вы получите письмо с деталями заказа</p>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3 mb-md-0">
                                <div class="text-center">
                                    <div class="step-icon mb-2">
                                        <i class="fas fa-box fa-2x text-primary"></i>
                                    </div>
                                    <h6>Комплектация</h6>
                                    <p class="small text-muted">Мы соберем ваш заказ в ближайшее время</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center">
                                    <div class="step-icon mb-2">
                                        <i class="fas fa-truck fa-2x text-primary"></i>
                                    </div>
                                    <h6>Доставка</h6>
                                    <p class="small text-muted">Отправим заказ после комплектации</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h6 class="mb-1">Нужна помощь?</h6>
                                <p class="text-muted small mb-0">Свяжитесь с нами по телефону или email</p>
                            </div>
                            <div class="col-md-4 text-md-end">
                                <a href="tel:+380441234567" class="btn btn-outline-primary">
                                    <i class="fas fa-phone me-2"></i>Связаться
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .success-section .card {
            border-radius: 16px;
            overflow: hidden;
        }
        
        .success-section .card-header {
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        
        .success-icon {
            animation: scaleIn 0.5s ease;
        }
        
        @@keyframes scaleIn {
            0% {
                transform: scale(0);
                opacity: 0;
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }
        
        .order-info {
            border-radius: 12px;
        }
        
        .step-icon {
            transition: transform 0.3s ease;
        }
        
        .step-icon:hover {
            transform: translateY(-5px);
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            transition: all 0.3s ease;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        
        .btn-outline-secondary {
            border: 1px solid #dee2e6;
            transition: all 0.3s ease;
        }
        
        .btn-outline-secondary:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        
        .btn-outline-primary {
            border-color: #667eea;
            color: #667eea;
            transition: all 0.3s ease;
        }
        
        .btn-outline-primary:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
            color: white;
            transform: translateY(-2px);
        }
        
        .breadcrumb {
            background: transparent;
        }
        
        .breadcrumb-item a {
            color: #667eea;
            text-decoration: none;
        }
        
        .breadcrumb-item.active {
            color: #6c757d;
        }
        
        .alert-info {
            background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
            border: none;
            border-radius: 12px;
            color: #1565c0;
        }
    </style>
}